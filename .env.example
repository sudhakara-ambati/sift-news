# Database — local dev uses SQLite via DATABASE_URL; production uses Turso.
# In Vercel, leave DATABASE_URL unset and set TURSO_* instead. When
# TURSO_DATABASE_URL is present, src/lib/db.ts switches Prisma to the
# libsql driver adapter automatically.
DATABASE_URL="file:./dev.db"

# Turso (production). Sign up at https://turso.tech, create a database, and
# copy the URL + auth token here. Also set these in the Vercel project's
# Environment Variables. To push the initial schema, run:
#   TURSO_DATABASE_URL=... TURSO_AUTH_TOKEN=... npm run db:push-turso
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Single-user admin credentials
ADMIN_USERNAME="your-username"
# Important: escape every `$` as `\$` (Next.js expands unescaped $VAR in env values)
ADMIN_PASSWORD_HASH="\$2b\$12\$example-hash-from-scripts/hash-password.ts"

# News sources
NEWSAPI_KEY="your-newsapi-key-from-newsapi.org"

# AI provider
AI_PROVIDER="gemini"
GEMINI_API_KEY="your-gemini-key-from-aistudio.google.com"
# Optional: preferred model (default: gemini-2.5-flash-lite).
# GEMINI_MODEL="gemini-2.5-flash-lite"
# Optional: comma-separated fallback chain when the primary hits 429 quota.
# Default cascade (Gemini first, Gemma as massive-quota backup):
#   gemini-2.5-flash-lite, gemini-2.5-flash, gemini-3-flash-lite-latest,
#   gemini-3-flash-latest, gemma-3-27b-it, gemma-3-12b-it, gemma-3-4b-it
# Gemma models have ~14,400 RPD each (vs ~20 RPD on Gemini free tier) but
# don't support Google Search grounding or JSON schema — summaries still
# work, but chat answers won't pull fresh web data.
# GEMINI_FALLBACK_MODELS="gemma-3-27b-it,gemma-3-12b-it"
# Optional: max approximate characters of chat history sent to Gemini each turn
# (newest turns are prioritised). Lower = cheaper/faster, higher = more context.
# AI_CHAT_HISTORY_CHAR_BUDGET="6000"
# Optional: enable second-pass AI refine for generated tag queries.
# Default is off to cut token use; set to 1 for higher query-polish at extra cost.
# AI_TAG_QUERY_REFINE="0"
# Optional: per-process guardrail for AI definition fallbacks in /api/define.
# Wikipedia is still attempted first and does not count towards this limit.
# MAX_AI_DEFINITIONS_PER_MINUTE="24"

# Protects /api/cron/fetch-news so only you (or Vercel Cron) can trigger it.
# Generate with: openssl rand -base64 32
# Clients must send it as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="random-string-for-cron-endpoint-auth"
